# Binaries (root-level build output only)
/docker-hash
*.exe
*.test

# Build output
/dist/

# Go vendor directory
/vendor/

# Defensive: markdown tooling is provisioned by mise, but if anyone runs
# `npm install` directly in the repo root these would land in the working
# tree. None of them should ever be committed in this Go repo.
/node_modules/
/package.json
/package-lock.json

# Local machine overrides for mise
.mise.local.toml
